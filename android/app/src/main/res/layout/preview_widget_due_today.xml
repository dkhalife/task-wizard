<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/preview_bg_surface_dark"
    android:clipToOutline="true">

    <!-- TitleBar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="fitCenter" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/widget_due_today_name"
            android:textColor="#DFE4DF"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Group header: Overdue (1) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:text="Overdue (1)"
        android:textColor="#F03A47"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- Task row: overdue -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="✓"
            android:textColor="#8CD5B8"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingEnd="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Send weekly report"
                android:textColor="#DFE4DF"
                android:textSize="14sp"
                android:maxLines="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yesterday · Work"
                android:textColor="#FFB4AB"
                android:textSize="11sp"
                android:maxLines="1" />
        </LinearLayout>
    </LinearLayout>

    <!-- Group header: Today (2) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:text="Today (2)"
        android:textColor="#FFC107"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- Task row: today -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="✓"
            android:textColor="#8CD5B8"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingEnd="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Team standup"
                android:textColor="#DFE4DF"
                android:textSize="14sp"
                android:maxLines="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today · Meetings"
                android:textColor="#BFC9C2"
                android:textSize="11sp"
                android:maxLines="1" />
        </LinearLayout>
    </LinearLayout>

    <!-- Task row: today -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="✓"
            android:textColor="#8CD5B8"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingEnd="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Review PRs"
                android:textColor="#DFE4DF"
                android:textSize="14sp"
                android:maxLines="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today · Work"
                android:textColor="#BFC9C2"
                android:textSize="11sp"
                android:maxLines="1" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
