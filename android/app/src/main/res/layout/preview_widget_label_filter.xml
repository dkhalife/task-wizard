<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/preview_bg_surface_dark"
    android:clipToOutline="true">

    <!-- TitleBar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="fitCenter" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Errands"
            android:textColor="#DFE4DF"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Task row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="✓"
            android:textColor="#8CD5B8"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingEnd="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Buy groceries"
                android:textColor="#DFE4DF"
                android:textSize="14sp"
                android:maxLines="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today · Errands"
                android:textColor="#BFC9C2"
                android:textSize="11sp"
                android:maxLines="1" />
        </LinearLayout>
    </LinearLayout>

    <!-- Task row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="✓"
            android:textColor="#8CD5B8"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingEnd="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pick up dry cleaning"
                android:textColor="#DFE4DF"
                android:textSize="14sp"
                android:maxLines="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tomorrow · Errands"
                android:textColor="#BFC9C2"
                android:textSize="11sp"
                android:maxLines="1" />
        </LinearLayout>
    </LinearLayout>

    <!-- Task row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="✓"
            android:textColor="#8CD5B8"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingEnd="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Return library books"
                android:textColor="#DFE4DF"
                android:textSize="14sp"
                android:maxLines="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This week · Errands"
                android:textColor="#BFC9C2"
                android:textSize="11sp"
                android:maxLines="1" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
